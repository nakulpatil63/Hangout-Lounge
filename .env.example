# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Backend server PORT config (production defaults)
PORT=3000

# Security secrets for enterprise authentication
JWT_SECRET=super_secret_hangout_key_change_in_production_123!
JWT_REFRESH_SECRET=refresh_super_secret_key_change_in_production_456!

# CORS Allowed Origin list (comma separated)
CORS_WHITELIST=*

# Persistent storage configurations (optional)
DB_PATH=./hangout.db
UPLOAD_DIR=./uploads

# Supabase Integration Credentials (Required)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

